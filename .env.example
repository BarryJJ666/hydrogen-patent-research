# ==============================================================================
# 氢能专利知识图谱研究平台 - 环境变量配置
# ==============================================================================
# 使用方法:
# 1. 复制此文件并重命名为 .env
# 2. 填入实际的配置值
# 3. 确保 .env 文件已添加到 .gitignore

# ==============================================================================
# Neo4j 数据库配置
# ==============================================================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here
NEO4J_DATABASE=neo4j

# ==============================================================================
# LLM API 配置
# ==============================================================================
# 通用配置
LLM_API_URL=https://your-llm-api-endpoint
LLM_API_KEY=your_api_key_here
LLM_SECRET_KEY=your_secret_key_here
LLM_BOT_ID=your_default_bot_id
LLM_TIMEOUT=60
LLM_MAX_RETRIES=5

# ==============================================================================
# 模型评测模块 - 各模型 Bot ID 配置
# ==============================================================================
# 如果使用百度内网API或类似服务，需要配置各模型的bot_id
MODEL_BOT_ID_QWEN35_35B=
MODEL_BOT_ID_QWEN3_235B=
MODEL_BOT_ID_GLM5=
MODEL_BOT_ID_DEEPSEEK_R1=
MODEL_BOT_ID_DEEPSEEK_V31=
MODEL_BOT_ID_DEEPSEEK_V32=
MODEL_BOT_ID_ERNIE45=

# ==============================================================================
# 本地模型路径配置（可选）
# ==============================================================================
# 如果使用本地vLLM推理，需要配置模型路径
LOCAL_MODEL_PATH=/path/to/your/models
MODEL_PATH_QWEN3_4B=/path/to/qwen3-4b
MODEL_PATH_QWEN3_8B=/path/to/qwen3-8b
MODEL_PATH_QWEN3_4B_SFT=/path/to/qwen3-4b-sft
MODEL_PATH_QWEN3_8B_SFT=/path/to/qwen3-8b-sft

# ==============================================================================
# 向量模型配置（可选）
# ==============================================================================
# 默认使用HuggingFace的BAAI/bge-m3，也可以指定本地路径
EMBEDDING_MODEL_PATH=BAAI/bge-m3

# ==============================================================================
# 数据路径配置（可选）
# ==============================================================================
RAW_DATA_DIR=./data/raw

# ==============================================================================
# 日志配置
# ==============================================================================
LOG_LEVEL=INFO
