MATCH (p:Patent {application_no: 'CN202411595627.6'}) MATCH (t:TechDomain {name: '制氢技术'}) MERGE (p)-[:BELONGS_TO]->(t);
MATCH (p:Patent {application_no: 'CN202411595627.6'}) MATCH (i:IPCCode {code: 'C25B15/02'}) MERGE (p)-[:CLASSIFIED_AS]->(i);
MATCH (p:Patent {application_no: 'CN202411595627.6'}) MATCH (c:Country {name: '中国'}) MERGE (p)-[:PUBLISHED_IN]->(c);
MATCH (p:Patent {application_no: 'CN202411595627.6'}) MATCH (l:LegalStatus {name: '实质审查'}) MERGE (p)-[:HAS_STATUS]->(l);
MATCH (p:Patent {application_no: 'CN202411595627.6'}) MATCH (f:PatentFamily {family_id: 'CN119685880A'}) MERGE (p)-[:IN_FAMILY]->(f);
MATCH (p:Patent {application_no: 'CN202411807069.5'}) MATCH (e:Organization {name: '北方工业大学'}) MERGE (p)-[:APPLIED_BY]->(e);
MATCH (p:Patent {application_no: 'CN202411807069.5'}) MATCH (e:Organization {name: '北方工业大学'}) MERGE (p)-[:OWNED_BY]->(e);