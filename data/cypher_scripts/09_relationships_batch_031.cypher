MATCH (p:Patent {application_no: 'WOEP24055009'}) MATCH (l:LegalStatus {name: '未进入国家阶段-PCT有效期内'}) MERGE (p)-[:HAS_STATUS]->(l);
MATCH (p:Patent {application_no: 'WOEP24055009'}) MATCH (f:PatentFamily {family_id: 'DE102023112290A1'}) MERGE (p)-[:IN_FAMILY]->(f);