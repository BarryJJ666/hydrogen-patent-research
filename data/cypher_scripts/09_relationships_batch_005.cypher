MATCH (p:Patent {application_no: 'US17441900'}) MATCH (i:IPCCode {code: 'F17C5/06'}) MERGE (p)-[:CLASSIFIED_AS]->(i);
MATCH (p:Patent {application_no: 'US17441900'}) MATCH (c:Country {name: '美国'}) MERGE (p)-[:PUBLISHED_IN]->(c);
MATCH (p:Patent {application_no: 'US17441900'}) MATCH (l:LegalStatus {name: '授权'}) MERGE (p)-[:HAS_STATUS]->(l);
MATCH (p:Patent {application_no: 'US17441900'}) MATCH (f:PatentFamily {family_id: 'US20220018498A1'}) MERGE (p)-[:IN_FAMILY]->(f);
MATCH (p:Patent {application_no: 'US18274933'}) MATCH (e:Organization {name: 'Grz Technologies SA'}) MERGE (p)-[:APPLIED_BY]->(e);
MATCH (p:Patent {application_no: 'US18274933'}) MATCH (e:Organization {name: 'Grz Technologies SA'}) MERGE (p)-[:OWNED_BY]->(e);
MATCH (p:Patent {application_no: 'US18274933'}) MATCH (e:Person {uid: 'Rubin,  Moritz@Rubin, Moritz'}) MERGE (p)-[:TRANSFERRED_FROM]->(e);