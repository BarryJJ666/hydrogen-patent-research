MATCH (p:Patent {application_no: 'CN202311612167.9'}) MATCH (e:Organization {name: '山西省科技情报与战略研究中心'}) MERGE (p)-[:APPLIED_BY]->(e);
MATCH (p:Patent {application_no: 'CN202311612167.9'}) MATCH (e:Organization {name: '山西省科技情报与战略研究中心'}) MERGE (p)-[:OWNED_BY]->(e);
MATCH (p:Patent {application_no: 'CN202311612167.9'}) MATCH (t:TechDomain {name: '物理储氢'}) MERGE (p)-[:BELONGS_TO]->(t);
MATCH (p:Patent {application_no: 'CN202311612167.9'}) MATCH (i:IPCCode {code: 'F17C1/12'}) MERGE (p)-[:CLASSIFIED_AS]->(i);
MATCH (p:Patent {application_no: 'CN202311612167.9'}) MATCH (c:Country {name: '中国'}) MERGE (p)-[:PUBLISHED_IN]->(c);
MATCH (p:Patent {application_no: 'CN202311612167.9'}) MATCH (l:LegalStatus {name: '实质审查'}) MERGE (p)-[:HAS_STATUS]->(l);
MATCH (p:Patent {application_no: 'CN202311612167.9'}) MATCH (f:PatentFamily {family_id: 'CN117628388A'}) MERGE (p)-[:IN_FAMILY]->(f);